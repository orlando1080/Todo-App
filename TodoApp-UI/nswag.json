{
  "runtime": "Default",
  "documentGenerator": {
    "aspNetCoreToOpenApi": {
      "project": "../src/TodoApp.Api/TodoApp.Api.csproj",
      "msBuildProjectExtensionsPath": "../src/TodoApp.Api/obj",
      "output": "openapi.json",
      "outputType": "OpenApi3"
    }
  },
  "codeGenerators": {
    "openApiToTypeScriptClient": {
      "className": "{controller}Client",
      "moduleName": "",
      "namespace": "",
      "template": "Angular",
      "injectionTokenType": "InjectionToken",
      "output": "src/app/api/api-client.generated.ts",
      "strictNullChecks": true,
      "nullValue": "Undefined",
      "generateOptionalParameters": true,
      "wrapResponses": false,
      "generateResponseClasses": false,
      "typeStyle": "Interface",
      "generateClientInterfaces": true
    }
  }
}
